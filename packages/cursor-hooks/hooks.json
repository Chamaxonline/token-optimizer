{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/session-start.js"
      }
    ],
    "sessionEnd": [
      {
        "command": "node .cursor/hooks/session-end.js"
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/pre-tool-use-read.js",
        "matcher": "Read"
      }
    ],
    "postToolUse": [
      {
        "command": "node .cursor/hooks/post-tool-use.js"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/before-submit-prompt.js",
        "matcher": "UserPromptSubmit"
      }
    ],
    "preCompact": [
      {
        "command": "node .cursor/hooks/pre-compact.js"
      }
    ]
  }
}
