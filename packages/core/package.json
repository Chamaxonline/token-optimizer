{
  "name": "@token-opt/core",
  "version": "0.1.0",
  "description": "Core token estimation and static analysis for token-optimizer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/session.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "js-tiktoken": "^1.0.20",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
