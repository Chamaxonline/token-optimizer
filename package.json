{
  "name": "token-optimizer",
  "private": true,
  "version": "0.3.0",
  "description": "Local CLI to scan and optimize token usage in Cursor and Claude Code",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @token-opt/cli dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "token-opt": "pnpm exec token-opt"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@token-opt/cli": "workspace:*",
    "@token-opt/cursor-hooks": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
